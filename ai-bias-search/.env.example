# Environment variables for AI Bias Search

# Semantic Scholar Graph API key (required for the semanticscholar connector)
SEMANTIC_SCHOLAR_API_KEY="your_semantic_scholar_key"

# Gemini API key (required for llm pipeline experiments using backend: gemini)
GEMINI_API_KEY="your_gemini_key"

# Perplexity API key (required for the perplexity connector)
PERPLEXITY_API_KEY="your_perplexity_key"

# Consensus API key (required for the consensus connector)
CONSENSUS_API_KEY="your_consensus_key"

# Scite API key (required for the scite connector)
SCITE_API_KEY="your_scite_key"

# CORE v3 API key (required for the core connector)
CORE_API_KEY="your_core_key"

# Elsevier Scopus API key (required only if scopus.enabled=true / scopus_enrich.enabled=true)
# You can use either SCOPUS_API_KEY or ELSEVIER_API_KEY.
SCOPUS_API_KEY="your_elsevier_key"
# ELSEVIER_API_KEY="your_elsevier_key"

# Optional: institutional token for Scopus requests
# SCOPUS_INSTTOKEN="your_institution_token"
# SCOPUS_INST_TOKEN="your_institution_token"

# Optional: Scopus API tuning
# SCOPUS_BASE_URL="https://api.elsevier.com"
# SCOPUS_TIMEOUT="20"
# SCOPUS_RPS="1"
# SCOPUS_MAX_RETRIES="3"

# Optional: Scopus rankings enrichment tuning (Serial Title API)
# SCOPUS_RANKINGS_API_KEY="your_elsevier_key"
# SCOPUS_RANKINGS_INSTTOKEN="your_institution_token"
# SCOPUS_RANKINGS_BASE_URL="https://api.elsevier.com"
# SCOPUS_RANKINGS_VIEW_PREFERENCE="ENHANCED,STANDARD"
# SCOPUS_RANKINGS_TIMEOUT_S="30"
# SCOPUS_RANKINGS_CACHE_TTL_DAYS="30"
# SCOPUS_RANKINGS_RPS="1"

# Optional: Scopus Search / Abstract defaults
# SCOPUS_SEARCH_VIEW="STANDARD"
# SCOPUS_ABSTRACT_VIEW="FULL"
# SCOPUS_ABSTRACT_FALLBACK_VIEWS="META,None"
# SCOPUS_SEARCH_FIELDS="dc:identifier,eid,prism:doi,dc:title"
# SCOPUS_ABSTRACT_FIELDS="dc:identifier,prism:doi,prism:coverDate,citedby-count"
# SCOPUS_ABSTRACT_FIELDS_MINIMAL="dc:title,prism:doi,prism:publicationName,prism:issn,prism:coverDate,citedby-count,openaccessFlag,subtype,subtypeDescription,affiliation-country,affilname"
# SCOPUS_FAIL_OPEN="true"

# Optional: override default logging level (e.g. DEBUG, INFO)
# LOG_LEVEL="INFO"

# Optional: choose CORE search method (AUTO tries GET then POST)
# CORE_SEARCH_METHOD="AUTO"

# Optional: override the CORE rankings dataset path (defaults to the packaged dataset)
# CORE_RANKINGS_PATH="/path/to/CORE.csv"

# Optional: shared User-Agent used by some connectors/enrichers
# AI_BIAS_USER_AGENT="ai-bias-search/0.1 (+contact@example.com)"
