<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>AI Bias Search Report</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 1.5rem; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 2rem; }
    th, td { border: 1px solid #ccc; padding: 0.5rem; text-align: left; }
    th { background-color: #f5f5f5; }
    h1, h2 { color: #333; }
    pre { background-color: #f5f5f5; padding: 0.5rem; }
  </style>
</head>
<body>
  <h1>AI Bias Search – Evaluation Report</h1>
  <section>
    <h2>Summary</h2>
    <p>Total records: {{ summary.total_records }}</p>
    <p>Platforms: {{ summary.platforms | join(", ") }}</p>
  </section>

  <section>
    <h2>Metrics</h2>
    {% for name, value in metrics.items() %}
    <h3>{{ name }}</h3>
    <pre>{{ value | tojson(indent=2) }}</pre>
    {% endfor %}
  </section>

  <section>
    <h2>Sample Records</h2>
    {% if table %}
    <table>
      <thead>
        <tr>
          {% for key in table[0].keys() %}
          <th>{{ key }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in table %}
        <tr>
          {% for value in row.values() %}
          <td>{{ value }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No sample records available.</p>
    {% endif %}
  </section>
</body>
</html>
