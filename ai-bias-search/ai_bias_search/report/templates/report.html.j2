<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ report_title or "Bias exploration" }}</title>
  <style>
    :root {
      --bg: #f4f6f8;
      --card: #ffffff;
      --line: #d8dde3;
      --text: #1f2a35;
      --muted: #5d6b79;
      --accent: #1f7a8c;
      --accent-2: #bf4f34;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", "Helvetica Neue", sans-serif;
      color: var(--text);
      background: linear-gradient(180deg, #f8fafc 0%, #eef3f7 100%);
    }
    .layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 1rem;
      max-width: 1600px;
      margin: 0 auto;
      padding: 1rem;
    }
    .sidebar {
      position: sticky;
      top: 1rem;
      align-self: start;
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 1rem;
      max-height: calc(100vh - 2rem);
      overflow: auto;
    }
    .sidebar h2 { margin: 0 0 0.75rem; font-size: 1rem; }
    .sidebar a {
      display: block;
      color: var(--muted);
      text-decoration: none;
      margin: 0.32rem 0;
      padding: 0.2rem 0.25rem;
      border-radius: 6px;
    }
    .sidebar a:hover { background: #eef4f9; color: var(--text); }
    main { min-width: 0; }
    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }
    h1 { margin: 0 0 0.2rem; font-size: 1.8rem; }
    h2 { margin-top: 0; }
    .muted { color: var(--muted); }

    .controls {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 0.7rem;
      margin-bottom: 0.9rem;
    }
    .controls label {
      display: block;
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 0.2rem;
    }
    .controls select,
    .controls input[type="text"] {
      width: 100%;
      padding: 0.45rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fff;
      color: var(--text);
    }
    .toggle {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.2rem;
      color: var(--muted);
      font-size: 0.86rem;
    }

    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 0.9rem;
    }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.7rem;
      margin-bottom: 0.8rem;
    }
    .stat-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0.65rem;
      background: #fcfdff;
    }
    .stat-card .label {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 0.2rem;
    }
    .stat-card .value {
      font-size: 1.05rem;
      font-weight: 600;
    }
    .chart-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 0.75rem;
      background: #fcfdff;
    }
    .chart-card h3 { margin: 0 0 0.45rem; font-size: 1rem; }
    .chart-box { min-height: 260px; }
    .plot-placeholder { color: #8b1f1f; font-size: 0.86rem; margin-top: 0.45rem; }

    .warning-list { margin: 0; padding-left: 1.1rem; }

    details {
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 0.5rem 0.7rem;
      margin: 0.6rem 0;
      background: #fbfcfe;
    }
    details > summary {
      cursor: pointer;
      font-weight: 600;
      color: var(--accent);
    }
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 0.84rem;
      background: #f5f7fa;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 0.6rem;
      overflow-x: auto;
    }

    .table-toolbar {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 0.45rem;
    }
    .table-filter {
      padding: 0.38rem 0.45rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      min-width: 220px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.86rem;
      background: white;
    }
    th, td {
      border: 1px solid var(--line);
      padding: 0.42rem;
      text-align: left;
      vertical-align: top;
    }
    th {
      cursor: pointer;
      background: #eef4f8;
      user-select: none;
      position: sticky;
      top: 0;
      z-index: 1;
    }
    .table-wrap { max-height: 360px; overflow: auto; border: 1px solid var(--line); border-radius: 10px; }

    .downloads a { color: var(--accent); }

    @media (max-width: 1100px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; max-height: none; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <h2>Contents</h2>
      <a href="#summary">Summary</a>
      <a href="#interactive">Interactive Charts</a>
      <a href="#compare">{{ entity_label_singular }} Compare</a>
      <a href="#missingness">Missingness</a>
      <a href="#enrichment">Enrichment Gain</a>
      <a href="#overlap">Record Overlap</a>
      <a href="#rank-bias">Ranking Bias</a>
      <a href="#geo-bias">Geo Bias</a>
      <a href="#venue-diversity">Venue Diversity</a>
      {% if llm_specific and llm_specific.present %}
      <a href="#llm-hallucination">LLM Verification</a>
      <a href="#llm-parse">Parse Robustness</a>
      <a href="#llm-divergence">Cross-Model Divergence</a>
      <a href="#llm-stability">Repeatability</a>
      <a href="#llm-usefulness">Bibliographic Quality</a>
      <a href="#llm-conflicts">Metadata Conflicts</a>
      <a href="#llm-query-details">LLM Query Details</a>
      {% endif %}
      <a href="#notes">Notes / Gating</a>
      <a href="#downloads">Download data</a>
      <a href="#jif-jcr">JIF / JCR</a>
      <a href="#tables">Tables</a>
      <a href="#raw-json">Raw JSON</a>
    </aside>

    <main>
      <section id="summary" class="card">
        <h1>{{ report_title or "AI Bias exploration Report" }}</h1>
        <p class="muted">Total records: {{ summary.total_records }} | {{ entity_label_plural }}: {{ summary.platforms | join(", ") }}</p>
        {% if metrics_timestamp %}
        <p class="muted">Metrics ({{ metrics_timestamp }})</p>
        {% else %}
        <p class="muted">No metrics available.</p>
        {% endif %}
        {% if llm_specific and llm_specific.present %}
        <p class="muted">Queries: {{ llm_specific.query_count }} | Calls: {{ llm_specific.call_count }}</p>
        {% endif %}
      </section>

      <section id="interactive" class="card">
        <h2>Interactive visualizations</h2>
        <div class="controls">
          <div>
            <label for="platform-filter">{{ entity_label_singular }}</label>
            <select id="platform-filter">
              {% for platform in interactive.payload.platforms %}
              <option value="{{ platform }}">{{ platform }}</option>
              {% endfor %}
            </select>
          </div>
          <div>
            <label for="metric-group-filter">Metric Group</label>
            <select id="metric-group-filter">
              {% for group in interactive.payload.metric_groups %}
              <option value="{{ group.id }}">{{ group.label }}</option>
              {% endfor %}
            </select>
          </div>
          <div>
            <label for="top-k-filter">Top-K</label>
            <select id="top-k-filter">
              {% for k in interactive.payload.top_ks %}
              <option value="{{ k }}">{{ k }}</option>
              {% endfor %}
            </select>
          </div>
          <div>
            <label for="compare-mode-filter">Compare Mode</label>
            <select id="compare-mode-filter">
              {% for mode in interactive.payload.compare_modes %}
              <option value="{{ mode }}">{{ mode }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="toggle"><input type="checkbox" id="hide-low-reliability" /><label for="hide-low-reliability">Hide low-reliability</label></div>
          <div class="toggle"><input type="checkbox" id="show-missingness-overlay" /><label for="show-missingness-overlay">Show missingness overlay</label></div>
        </div>

        <div class="chart-grid">
          <div class="chart-card" data-group="recency">
            <h3>Recency Distribution</h3>
            <div id="chart-recency" class="chart-box"></div>
            <div id="placeholder-recency" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="citations">
            <h3>Rank vs Citations</h3>
            <div id="chart-rank-citations" class="chart-box"></div>
            <div id="placeholder-rank-citations" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="oa">
            <h3>OA Top-K vs Overall</h3>
            <div id="chart-oa-topk" class="chart-box"></div>
            <div id="placeholder-oa-topk" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="doc_type">
            <h3>Doc Type Top-K vs Overall</h3>
            <div id="chart-doc-type" class="chart-box"></div>
            <div id="placeholder-doc-type" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="venue_concentration">
            <h3>Publisher Concentration (HHI)</h3>
            <div id="chart-hhi" class="chart-box"></div>
            <div id="placeholder-hhi" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="oa">
            <h3>OA Share vs Recency</h3>
            <div id="chart-oa-recency" class="chart-box"></div>
            <div id="placeholder-oa-recency" class="plot-placeholder"></div>
          </div>
        </div>
      </section>

      <section id="compare" class="card">
        <h2>{{ entity_label_singular }} Compare</h2>
        <div id="chart-platform-compare" class="chart-box"></div>
        <div id="placeholder-platform-compare" class="plot-placeholder"></div>
      </section>

      <section id="missingness" class="card">
        <h2>Missingness Heatmap</h2>
        <div id="chart-missingness" class="chart-box"></div>
        <div id="placeholder-missingness" class="plot-placeholder"></div>
      </section>

      <section id="enrichment" class="card">
        <h2>Enrichment Gain (Before vs After)</h2>
        <div id="chart-enrichment-gain" class="chart-box"></div>
        <div id="placeholder-enrichment-gain" class="plot-placeholder"></div>
      </section>

      <section id="overlap" class="card">
        <h2>Record Overlap (Jaccard Heatmap)</h2>
        <div id="chart-overlap" class="chart-box"></div>
        <div id="placeholder-overlap" class="plot-placeholder"></div>
      </section>

      <section id="rank-bias" class="card">
        <h2>Ranking Bias Panels</h2>
        <div class="chart-grid">
          <div class="chart-card">
            <h3>CORE Rank (A*+A) Share: Top-K vs Rest</h3>
            <div id="chart-core-rank-bias" class="chart-box"></div>
            <div id="placeholder-core-rank-bias" class="plot-placeholder"></div>
          </div>
          <div class="chart-card">
            <h3>JIF Quartile (Q1) Share: Top-K vs Rest</h3>
            <div id="chart-jif-quartile-bias" class="chart-box"></div>
            <div id="placeholder-jif-quartile-bias" class="plot-placeholder"></div>
          </div>
        </div>
      </section>

      <section id="geo-bias" class="card">
        <h2>Geo Bias</h2>
        <div class="controls">
          <div>
            <label for="geo-variant-filter">Geo Variant</label>
            <select id="geo-variant-filter">
              <option value="fractional">fractional</option>
              <option value="dominant">dominant</option>
            </select>
          </div>
          <div>
            <label for="geo-granularity-filter">Geo Granularity</label>
            <select id="geo-granularity-filter">
              <option value="countries">countries</option>
              <option value="regions">regions</option>
            </select>
          </div>
        </div>
        <div class="stat-grid">
          <div class="stat-card">
            <div class="label">Available share</div>
            <div id="geo-available-share" class="value">-</div>
          </div>
          <div class="stat-card">
            <div class="label">Multi-country share</div>
            <div id="geo-multi-share" class="value">-</div>
          </div>
          <div class="stat-card">
            <div class="label">Bias gating</div>
            <div id="geo-enabled" class="value">-</div>
          </div>
          <div class="stat-card">
            <div class="label">Gating reason</div>
            <div id="geo-reason" class="value">-</div>
          </div>
        </div>
        <div class="chart-grid">
          <div class="chart-card" data-group="geo">
            <h3>Top Geo Distribution: overall vs top-k</h3>
            <div id="chart-geo-top" class="chart-box"></div>
            <div id="placeholder-geo-top" class="plot-placeholder"></div>
          </div>
          <div class="chart-card" data-group="geo">
            <h3>Geo Over/Under Representation</h3>
            <div id="chart-geo-overunder" class="chart-box"></div>
            <div id="placeholder-geo-overunder" class="plot-placeholder"></div>
          </div>
        </div>
      </section>

      <section id="venue-diversity" class="card">
        <h2>Venue Diversity</h2>
        <div id="chart-venue-diversity" class="chart-box"></div>
        <div id="placeholder-venue-diversity" class="plot-placeholder"></div>
      </section>

      {% if llm_specific and llm_specific.present %}
      <section id="llm-hallucination" class="card">
        <h2>LLM Hallucination / Verifiability</h2>
        <div id="chart-llm-hallucination" class="chart-box"></div>
        <div id="placeholder-llm-hallucination" class="plot-placeholder"></div>
        <div class="table-wrap">
          <table class="js-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>DOI Rate</th>
                <th>Matched Rate</th>
                <th>Unmatched Rate</th>
                <th>Conflict Rate</th>
              </tr>
            </thead>
            <tbody>
              {% for row in llm_specific.hallucination_rows %}
              <tr>
                <td>{{ row.model }}</td>
                <td>{{ "%.1f%%"|format((row.valid_doi_proportion or 0) * 100) if row.valid_doi_proportion is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.matched_proportion or 0) * 100) if row.matched_proportion is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.unmatched_proportion or 0) * 100) if row.unmatched_proportion is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.any_conflict_rate or 0) * 100) if row.any_conflict_rate is not none else "N/A" }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      <section id="llm-parse" class="card">
        <h2>LLM Parse Robustness</h2>
        <div id="chart-llm-parse" class="chart-box"></div>
        <div id="placeholder-llm-parse" class="plot-placeholder"></div>
        <div class="table-wrap">
          <table class="js-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Calls</th>
                <th>Raw Success</th>
                <th>Strict JSON</th>
                <th>Fallback Parse</th>
                <th>Parse Failure</th>
              </tr>
            </thead>
            <tbody>
              {% for row in llm_specific.parse_rows %}
              <tr>
                <td>{{ row.model }}</td>
                <td>{{ row.call_count if row.call_count is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.raw_success_rate or 0) * 100) if row.raw_success_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.strict_json_rate or 0) * 100) if row.strict_json_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.repaired_parse_rate or 0) * 100) if row.repaired_parse_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.parse_failure_rate or 0) * 100) if row.parse_failure_rate is not none else "N/A" }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      <section id="llm-divergence" class="card">
        <h2>LLM Cross-Model Divergence</h2>
        <div class="table-wrap">
          <table class="js-table">
            <thead>
              <tr>
                <th>Left Model</th>
                <th>Right Model</th>
                <th>Mean Jaccard</th>
                <th>Overlap@5</th>
                <th>Top-1 Agreement</th>
                <th>Comparisons</th>
              </tr>
            </thead>
            <tbody>
              {% for row in llm_specific.cross_model_rows %}
              <tr>
                <td>{{ row.left_model }}</td>
                <td>{{ row.right_model }}</td>
                <td>{{ "%.3f"|format(row.mean_jaccard) if row.mean_jaccard is not none else "N/A" }}</td>
                <td>{{ "%.3f"|format(row.mean_overlap_at_5) if row.mean_overlap_at_5 is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.top1_agreement or 0) * 100) if row.top1_agreement is not none else "N/A" }}</td>
                <td>{{ row.comparisons }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      <section id="llm-stability" class="card">
        <h2>LLM Stability / Repeatability</h2>
        <details open>
          <summary>Per-model stability summary</summary>
          <div class="table-wrap">
            <table class="js-table">
              <thead>
                <tr>
                  <th>Model</th>
                  <th>Mean Jaccard</th>
                  <th>Overlap@5</th>
                  <th>Year Variance</th>
                  <th>OA Variance</th>
                  <th>Citation Variance</th>
                  <th>Parse Failure</th>
                </tr>
              </thead>
              <tbody>
                {% for row in llm_specific.stability_summary_rows %}
                <tr>
                  <td>{{ row.model }}</td>
                  <td>{{ "%.3f"|format(row.mean_jaccard) if row.mean_jaccard is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.mean_overlap_at_5) if row.mean_overlap_at_5 is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.year_mean_variance) if row.year_mean_variance is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.oa_share_variance) if row.oa_share_variance is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.citation_mean_variance) if row.citation_mean_variance is not none else "N/A" }}</td>
                  <td>{{ "%.1f%%"|format((row.parse_failure_rate or 0) * 100) if row.parse_failure_rate is not none else "N/A" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
        <details>
          <summary>Per-query repeatability</summary>
          <div class="table-wrap">
            <table class="js-table">
              <thead>
                <tr>
                  <th>Model</th>
                  <th>Query</th>
                  <th>Repeats</th>
                  <th>Mean Jaccard</th>
                  <th>Overlap@5</th>
                  <th>Parse Failure</th>
                </tr>
              </thead>
              <tbody>
                {% for row in llm_specific.stability_rows %}
                <tr>
                  <td>{{ row.model }}</td>
                  <td>{{ row.query_id }}</td>
                  <td>{{ row.repeat_count }}</td>
                  <td>{{ "%.3f"|format(row.mean_jaccard) if row.mean_jaccard is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.mean_overlap_at_5) if row.mean_overlap_at_5 is not none else "N/A" }}</td>
                  <td>{{ "%.1f%%"|format((row.parse_failure_rate or 0) * 100) if row.parse_failure_rate is not none else "N/A" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
      </section>

      <section id="llm-usefulness" class="card">
        <h2>Retrieval Usefulness / Bibliographic Quality</h2>
        <div class="table-wrap">
          <table class="js-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Valid DOI</th>
                <th>Title Match</th>
                <th>Metadata Coverage</th>
                <th>Evaluable Records</th>
                <th>Mean Verifiable / Query</th>
              </tr>
            </thead>
            <tbody>
              {% for row in llm_specific.usefulness_rows %}
              <tr>
                <td>{{ row.model }}</td>
                <td>{{ "%.1f%%"|format((row.valid_doi_rate or 0) * 100) if row.valid_doi_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.title_match_rate or 0) * 100) if row.title_match_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.metadata_coverage_rate or 0) * 100) if row.metadata_coverage_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.evaluable_record_rate or 0) * 100) if row.evaluable_record_rate is not none else "N/A" }}</td>
                <td>{{ "%.2f"|format(row.mean_verifiable_per_query) if row.mean_verifiable_per_query is not none else "N/A" }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      <section id="llm-conflicts" class="card">
        <h2>LLM Claimed vs Enriched Metadata Conflicts</h2>
        <div class="table-wrap">
          <table class="js-table">
            <thead>
              <tr>
                <th>Model</th>
                <th>Any Conflict</th>
                <th>Year Conflict</th>
                <th>Journal Conflict</th>
                <th>DOI Conflict</th>
              </tr>
            </thead>
            <tbody>
              {% for row in llm_specific.conflict_rows %}
              <tr>
                <td>{{ row.model }}</td>
                <td>{{ "%.1f%%"|format((row.any_conflict_rate or 0) * 100) if row.any_conflict_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.year_conflict_rate or 0) * 100) if row.year_conflict_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.journal_conflict_rate or 0) * 100) if row.journal_conflict_rate is not none else "N/A" }}</td>
                <td>{{ "%.1f%%"|format((row.doi_conflict_rate or 0) * 100) if row.doi_conflict_rate is not none else "N/A" }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      <section id="llm-query-details" class="card">
        <h2>LLM Query Details</h2>
        <div class="table-toolbar">
          <input class="table-filter" id="llm-query-filter" placeholder="Filter query cards..." />
        </div>
        {% for query in llm_specific.query_details %}
        <details class="llm-query-card" data-search="{{ (query.query_id ~ ' ' ~ query.query_text ~ ' ' ~ (query.query_category or '') ~ ' ' ~ query.prompt_text)|lower }}">
          <summary>{{ query.query_id }} | {{ query.query_text }}</summary>
          <p class="muted">{{ query.query_category or "uncategorized" }}{% if query.query_language %} | {{ query.query_language }}{% endif %}</p>
          <pre>{{ query.prompt_text }}</pre>
          {% for response in query.responses %}
          <details>
            <summary>{{ response.model }} | repeat {{ response.repeat_index + 1 }} | {{ response.parse_status }}</summary>
            {% if response.error_message %}<p class="muted">Error: {{ response.error_message }}</p>{% endif %}
            <details>
              <summary>Parsed articles</summary>
              <pre>{{ response.article_recommendations | tojson(indent=2) }}</pre>
            </details>
            <details>
              <summary>Enriched recommendations</summary>
              <pre>{{ response.enriched_recommendations | tojson(indent=2) }}</pre>
            </details>
            <details>
              <summary>Raw output</summary>
              <pre>{{ response.raw_response_text or (response.raw_response_json | tojson(indent=2)) }}</pre>
            </details>
          </details>
          {% endfor %}
        </details>
        {% endfor %}
      </section>
      {% endif %}

      <section id="notes" class="card">
        <h2>Notes / Gating</h2>
        {% if interactive.payload.warnings %}
        <ul class="warning-list" id="gating-notes">
          {% for warning in interactive.payload.warnings %}
          <li>{{ warning }}</li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="muted">No gating warnings.</p>
        {% endif %}
      </section>

      <section id="downloads" class="card downloads">
        <h2>Download data</h2>
        <ul>
          <li>
            {% if interactive.downloads.metrics_json %}
            <a href="{{ interactive.downloads.metrics_json }}">Metrics JSON</a>
            {% else %}
            Metrics JSON: unavailable
            {% endif %}
          </li>
          <li>
            {% if interactive.downloads.enriched_dataset or interactive.downloads.enriched_parquet %}
            <a href="{{ interactive.downloads.enriched_dataset or interactive.downloads.enriched_parquet }}">{{ enriched_download_label or "Enriched Parquet" }}</a>
            {% else %}
            {{ enriched_download_label or "Enriched Parquet" }}: unavailable
            {% endif %}
          </li>
          <li>
            {% if interactive.downloads.chart_data_csv %}
            <a href="{{ interactive.downloads.chart_data_csv }}">Chart aggregates CSV</a>
            {% else %}
            Chart aggregates CSV: unavailable
            {% endif %}
          </li>
        </ul>
      </section>

      <section id="jif-jcr" class="card">
        <h2>Journal Impact Factor (JIF/JCR)</h2>
        {% if jcr_summary %}
        <div class="table-toolbar"><input class="table-filter" data-target="table-jcr-summary" placeholder="Filter rows..." /></div>
        <div class="table-wrap">
          <table id="table-jcr-summary" class="js-table">
            <thead>
              <tr><th>{{ entity_label_singular }}</th><th>Eligible</th><th>Mean IF</th><th>Median IF</th><th>Median JCI</th><th>Q1 share</th><th>Missing</th><th>Top publishers</th></tr>
            </thead>
            <tbody>
              {% for row in jcr_summary %}
              <tr>
                <td>{{ row.platform }}</td>
                <td>{{ row.eligible_count if row.eligible_count is not none else "N/A" }}</td>
                <td>{{ "%.3f"|format(row.mean) if row.mean is not none else "N/A" }}</td>
                <td>{{ "%.3f"|format(row.median) if row.median is not none else "N/A" }}</td>
                <td>{{ "%.3f"|format(row.median_jci) if row.median_jci is not none else "N/A" }}</td>
                <td>{{ "%.3f"|format(row.q1_share) if row.q1_share is not none else "N/A" }}</td>
                <td>{{ row.missing_count if row.missing_count is not none else "N/A" }}</td>
                <td>{{ row.top_publishers if row.top_publishers else "-" }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="muted">No JCR summary available.</p>
        {% endif %}
      </section>

      <section id="tables" class="card">
        <h2>Tables</h2>

        <details open>
          <summary>Bias Features Availability by {{ entity_label_singular }}</summary>
          {% if bias_features_availability %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-bias-features" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-bias-features" class="js-table">
              <thead>
                <tr>
                  <th>{{ entity_label_singular }}</th><th>Total</th><th>OA %</th><th>Country %</th><th>Citations %</th><th>Doc type %</th><th>Publisher %</th><th>ISSN %</th>
                </tr>
              </thead>
              <tbody>
                {% for row in bias_features_availability %}
                <tr>
                  <td>{{ row.platform }}</td>
                  <td>{{ row.total }}</td>
                  <td>{{ "%.1f%%"|format(row.oa_pct) }}</td>
                  <td>{{ "%.1f%%"|format(row.country_pct) }}</td>
                  <td>{{ "%.1f%%"|format(row.citations_pct) }}</td>
                  <td>{{ "%.1f%%"|format(row.doc_type_pct) }}</td>
                  <td>{{ "%.1f%%"|format(row.publisher_pct) }}</td>
                  <td>{{ "%.1f%%"|format(row.issn_pct) }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<p>No rows.</p>{% endif %}
        </details>

        <details>
          <summary>Top-K Bias Summary</summary>
          {% if top_k_bias_summary %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-topk" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-topk" class="js-table">
              <thead>
                <tr>
                  <th>{{ entity_label_singular }}</th><th>K</th><th>OA top-K</th><th>OA overall</th><th>OA delta</th><th>Citation Spearman</th>
                </tr>
              </thead>
              <tbody>
                {% for row in top_k_bias_summary %}
                <tr>
                  <td>{{ row.platform }}</td>
                  <td>{{ row.k }}</td>
                  <td>{{ "%.3f"|format(row.oa_top_k_share) if row.oa_top_k_share is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.oa_overall_share) if row.oa_overall_share is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.oa_delta_share) if row.oa_delta_share is not none else "N/A" }}</td>
                  <td>{{ "%.3f"|format(row.citation_spearman) if row.citation_spearman is not none else "N/A" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<p>No rows.</p>{% endif %}
        </details>

        <details>
          <summary>CORE Ranking</summary>
          {% if core_ranking_table %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-core-ranking" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-core-ranking" class="js-table">
              <thead><tr><th>{{ entity_label_singular }}</th><th>Eligible</th><th>A*</th><th>A</th><th>B</th><th>C</th><th>Missing</th></tr></thead>
              <tbody>
                {% for row in core_ranking_table %}
                <tr>
                  <td>{{ row.platform }}</td>
                  <td>{{ row.eligible_count if row.eligible_count is not none else "N/A" }}</td>
                  <td>{{ row.a_star_count if row.a_star_count is not none else "N/A" }}</td>
                  <td>{{ row.a_count if row.a_count is not none else "N/A" }}</td>
                  <td>{{ row.b_count if row.b_count is not none else "N/A" }}</td>
                  <td>{{ row.c_count if row.c_count is not none else "N/A" }}</td>
                  <td>{{ row.missing_count if row.missing_count is not none else "N/A" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<p>No rows.</p>{% endif %}
        </details>

        <details>
          <summary>CORE match source breakdown</summary>
          {% if core_match_source_breakdown %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-core-match-source" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-core-match-source" class="js-table">
              <thead><tr><th>{{ entity_label_singular }}</th><th>Total</th><th>Matched</th><th>Matched %</th><th>ISSN</th><th>Title</th><th>Fuzzy</th><th>Unmatched</th></tr></thead>
              <tbody>
                {% for row in core_match_source_breakdown %}
                <tr>
                  <td>{{ row.platform }}</td>
                  <td>{{ row.total }}</td>
                  <td>{{ row.matched_count }}</td>
                  <td>{{ "%.1f%%"|format(row.matched_pct) if row.matched_pct is not none else "N/A" }}</td>
                  <td>{{ row.issn_count }}</td>
                  <td>{{ row.title_count }}</td>
                  <td>{{ row.fuzzy_count }}</td>
                  <td>{{ row.unmatched_count }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<p>No rows.</p>{% endif %}
        </details>

        <details>
          <summary>Citations quality diagnostics</summary>
          {% if citations_quality_rows %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-citations-quality" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-citations-quality" class="js-table">
              <thead><tr><th>{{ entity_label_singular }}</th><th>Total</th><th>Known %</th><th>OK</th><th>Missing</th><th>Suspicious</th></tr></thead>
              <tbody>
                {% for row in citations_quality_rows %}
                <tr>
                  <td>{{ row.platform }}</td>
                  <td>{{ row.total }}</td>
                  <td>{{ "%.1f%%"|format(row.known_pct) }}</td>
                  <td>{{ row.ok_count }}</td>
                  <td>{{ row.missing_count }}</td>
                  <td>{{ row.suspicious_count }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% else %}<p>No rows.</p>{% endif %}
        </details>

        <details>
          <summary>Sample Records</summary>
          {% if table %}
          <div class="table-toolbar"><input class="table-filter" data-target="table-sample-records" placeholder="Filter rows..." /></div>
          <div class="table-wrap">
            <table id="table-sample-records" class="js-table">
              <thead>
                <tr>
                  {% for key in table[0].keys() %}
                  <th>{{ key }}</th>
                  {% endfor %}
                </tr>
              </thead>
              <tbody>
                {% for row in table %}
                <tr>
                  {% for value in row.values() %}
                  <td>{{ value }}</td>
                  {% endfor %}
