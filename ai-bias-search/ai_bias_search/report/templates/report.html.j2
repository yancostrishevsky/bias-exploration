<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Bias exploration</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 1.5rem; color: #222; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 2rem; }
    th, td { border: 1px solid #ccc; padding: 0.5rem; text-align: left; }
    th { background-color: #f5f5f5; }
    h1, h2 { color: #333; }
    pre { background-color: #f5f5f5; padding: 0.5rem; overflow-x: auto; }
    .charts { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1rem; }
    .chart-card { border: 1px solid #ddd; border-radius: 8px; padding: 0.75rem; background: #fafafa; }
    .chart-card h3 { margin-top: 0; }
    .chart-card img { max-width: 100%; height: auto; display: block; }
  </style>
</head>
<body>
  <h1>AI Bias exploration Report</h1>
  <section>
    <h2>Summary</h2>
    <p>Total records: {{ summary.total_records }}</p>
    <p>Platforms: {{ summary.platforms | join(", ") }}</p>
  </section>

  <section>
    <h2>Visualizations</h2>
    {% if plots %}
    <div class="charts">
      {% for plot in plots %}
      <div class="chart-card">
        <h3>{{ plot.title }}</h3>
        <img src="data:image/png;base64,{{ plot.data_url }}" alt="{{ plot.title }}" />
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p>No visualizations available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Metrics{% if metrics_timestamp %} ({{ metrics_timestamp }}){% endif %}</h2>
    {% if latest_metrics %}
      {% if latest_metrics.biases %}
      <h3>Bias metrics (overall)</h3>
      {% if latest_metrics.biases.citations_not_cross_platform_comparable %}
      <p><em>Note: citations are reported per platform and are not treated as cross-platform comparable.</em></p>
      {% endif %}
      <pre>{{ latest_metrics.biases | tojson(indent=2) }}</pre>
      {% if latest_metrics.biases.by_platform %}
      <h4>Bias metrics by platform</h4>
      {% for platform, vals in latest_metrics.biases.by_platform.items() %}
      <h5>{{ platform }}</h5>
      <pre>{{ vals | tojson(indent=2) }}</pre>
      {% endfor %}
      {% endif %}
      {% endif %}

      <h3>Pairwise ranking similarity</h3>
      {% if latest_metrics.pairwise %}
      <table>
        <thead>
          <tr>
            <th>Platform pair</th>
            <th>Jaccard</th>
            <th>Overlap@k</th>
            <th>RBO</th>
          </tr>
        </thead>
        <tbody>
          {% for key, vals in latest_metrics.pairwise.items() %}
          <tr>
            <td>{{ key }}</td>
            {% set j = vals.get("jaccard") %}
            {% set o = vals.get("overlap_at_k") %}
            {% set r = vals.get("rbo") %}
            <td>{{ "%.3f"|format(j) if j is not none else "N/A" }}</td>
            <td>{{ "%.3f"|format(o) if o is not none else "N/A" }}</td>
            <td>{{ "%.3f"|format(r) if r is not none else "N/A" }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p>No pairwise metrics available.</p>
      {% endif %}

      {% if latest_metrics.source %}
      <p><em>Metrics source: {{ latest_metrics.source }}</em></p>
      {% endif %}
    {% else %}
    <p>No metrics available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Bias Features Availability by Platform</h2>
    {% if bias_features_availability %}
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Total</th>
          <th>OA available</th>
          <th>Country available</th>
          <th>Citations available</th>
          <th>Doc type available</th>
          <th>Publisher available</th>
          <th>ISSN available</th>
        </tr>
      </thead>
      <tbody>
        {% for row in bias_features_availability %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.total }}</td>
          <td>{{ row.oa_count }} ({{ "%.1f%%"|format(row.oa_pct) }})</td>
          <td>{{ row.country_count }} ({{ "%.1f%%"|format(row.country_pct) }})</td>
          <td>{{ row.citations_count }} ({{ "%.1f%%"|format(row.citations_pct) }})</td>
          <td>{{ row.doc_type_count }} ({{ "%.1f%%"|format(row.doc_type_pct) }})</td>
          <td>{{ row.publisher_count }} ({{ "%.1f%%"|format(row.publisher_pct) }})</td>
          <td>{{ row.issn_count }} ({{ "%.1f%%"|format(row.issn_pct) }})</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No bias feature availability summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Top-K Bias Summary</h2>
    {% if top_k_bias_summary %}
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>K</th>
          <th>OA top-K</th>
          <th>OA overall</th>
          <th>OA delta</th>
          <th>OA reliability</th>
          <th>Country JS divergence</th>
          <th>Country reliability</th>
          <th>Doc type JS divergence</th>
          <th>Doc type reliability</th>
          <th>Citation Spearman</th>
          <th>Citations median top-K</th>
          <th>Citations median rest</th>
          <th>Citations reliability</th>
        </tr>
      </thead>
      <tbody>
        {% for row in top_k_bias_summary %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.k }}</td>
          <td>{{ "%.3f"|format(row.oa_top_k_share) if row.oa_top_k_share is not none else "N/A" }}</td>
          <td>{{ "%.3f"|format(row.oa_overall_share) if row.oa_overall_share is not none else "N/A" }}</td>
          <td>{{ "%.3f"|format(row.oa_delta_share) if row.oa_delta_share is not none else "N/A" }}</td>
          <td>{{ row.oa_reliability if row.oa_reliability is not none else "N/A" }}</td>
          <td>{{ "%.3f"|format(row.country_js_divergence) if row.country_js_divergence is not none else "N/A" }}</td>
          <td>{{ row.country_reliability if row.country_reliability is not none else "N/A" }}</td>
          <td>{{ "%.3f"|format(row.doc_type_js_divergence) if row.doc_type_js_divergence is not none else "N/A" }}</td>
          <td>{{ row.doc_type_reliability if row.doc_type_reliability is not none else "N/A" }}</td>
          <td>{{ "%.3f"|format(row.citation_spearman) if row.citation_spearman is not none else "N/A" }}</td>
          <td>{{ "%.2f"|format(row.citation_median_top_k) if row.citation_median_top_k is not none else "N/A" }}</td>
          <td>{{ "%.2f"|format(row.citation_median_rest) if row.citation_median_rest is not none else "N/A" }}</td>
          <td>{{ row.citation_reliability if row.citation_reliability is not none else "N/A" }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No top-k bias summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>CORE match source breakdown</h2>
    {% if core_match_source_breakdown %}
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Total</th>
          <th>Matched</th>
          <th>Matched %</th>
          <th>ISSN</th>
          <th>Title</th>
          <th>Fuzzy</th>
          <th>Unmatched</th>
        </tr>
      </thead>
      <tbody>
        {% for row in core_match_source_breakdown %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.total }}</td>
          <td>{{ row.matched_count }}</td>
          <td>{{ "%.1f%%"|format(row.matched_pct) }}</td>
          <td>{{ row.issn_count }}</td>
          <td>{{ row.title_count }}</td>
          <td>{{ row.fuzzy_count }}</td>
          <td>{{ row.unmatched_count }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No CORE matching source summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Citations quality diagnostics</h2>
    {% if citations_quality_rows %}
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Total</th>
          <th>Known citations</th>
          <th>Quality ok</th>
          <th>Quality missing</th>
          <th>Quality suspicious</th>
        </tr>
      </thead>
      <tbody>
        {% for row in citations_quality_rows %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.total }}</td>
          <td>{{ row.known_count }} ({{ "%.1f%%"|format(row.known_pct) }})</td>
          <td>{{ row.ok_count }}</td>
          <td>{{ row.missing_count }}</td>
          <td>{{ row.suspicious_count }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No citations quality diagnostics available.</p>
    {% endif %}

    {% if diagnostics and diagnostics.warnings %}
    <h3>Sanity warnings</h3>
    <ul>
      {% for warning in diagnostics.warnings %}
      <li>{{ warning }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>

  <section>
    <h2>CORE ranking</h2>
    {% if core_ranking_table %}
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Eligible records</th>
          <th>A* count</th>
          <th>A* share</th>
          <th>A count</th>
          <th>A share</th>
          <th>B count</th>
          <th>B share</th>
          <th>C count</th>
          <th>C share</th>
          <th>Missing count</th>
          <th>Missing share</th>
        </tr>
      </thead>
      <tbody>
        {% for row in core_ranking_table %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.eligible_count if row.eligible_count is not none else "N/A" }}</td>
          <td>{{ row.a_star_count if row.a_star_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.a_star_share * 100) if row.a_star_share is not none else "N/A" }}</td>
          <td>{{ row.a_count if row.a_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.a_share * 100) if row.a_share is not none else "N/A" }}</td>
          <td>{{ row.b_count if row.b_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.b_share * 100) if row.b_share is not none else "N/A" }}</td>
          <td>{{ row.c_count if row.c_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.c_share * 100) if row.c_share is not none else "N/A" }}</td>
          <td>{{ row.missing_count if row.missing_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.missing_share * 100) if row.missing_share is not none else "N/A" }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No CORE ranking summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Rankings coverage</h2>
    {% if rankings_coverage_table %}
    <table>
      <thead>
        <tr>
          <th>Ranking</th>
          <th>Matched</th>
          <th>Total</th>
          <th>Matched %</th>
          <th>Method breakdown</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rankings_coverage_table %}
        <tr>
          <td>{{ row.ranking_id }}</td>
          <td>{{ row.matched_count }}</td>
          <td>{{ row.total }}</td>
          <td>{{ "%.1f%%"|format(row.matched_pct) }}</td>
          <td>{{ row.method_breakdown }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No ranking coverage summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Journal Impact Factor (JIF/JCR)</h2>
    <p>
      Optional JIF/JCR enrichment can reveal systematic differences in journal visibility/coverage across platforms
      (match quality, quartiles, publishers).
    </p>
    {% if jif_enabled %}
      <p>Coverage: {{ "%.1f%%"|format(jif_coverage_pct) }} of records have an impact factor.</p>
      {% if jif_publisher_hhi_text %}
      <p><em>{{ jif_publisher_hhi_text }}</em></p>
      {% endif %}
      {% if jif_rank_corr_text %}
      <p><em>{{ jif_rank_corr_text }}</em></p>
      {% endif %}
      <div class="charts">
        {% if jif_match_plot_png %}
        <div class="chart-card">
          <h3>JIF match quality</h3>
          <img src="data:image/png;base64,{{ jif_match_plot_png }}" alt="JIF match quality" />
        </div>
        {% endif %}
        {% if jif_distribution_plot_png %}
        <div class="chart-card">
          <h3>Impact factor distribution</h3>
          <img src="data:image/png;base64,{{ jif_distribution_plot_png }}" alt="Impact factor distribution" />
        </div>
        {% endif %}
        {% if jif_quartile_plot_png %}
        <div class="chart-card">
          <h3>JCR quartiles</h3>
          <img src="data:image/png;base64,{{ jif_quartile_plot_png }}" alt="JCR quartile distribution" />
        </div>
        {% endif %}
        {% if jif_publisher_plot_png %}
        <div class="chart-card">
          <h3>Top JCR publishers</h3>
          <img src="data:image/png;base64,{{ jif_publisher_plot_png }}" alt="Top JCR publishers" />
        </div>
        {% endif %}
        {% if jif_rank_plot_png %}
        <div class="chart-card">
          <h3>Rank vs impact factor</h3>
          <img src="data:image/png;base64,{{ jif_rank_plot_png }}" alt="Rank vs impact factor" />
        </div>
        {% endif %}
      </div>
    {% else %}
      <p>{{ jif_message }}</p>
    {% endif %}
    {% if jcr_summary %}
    <h3>Summary table</h3>
    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Eligible records</th>
          <th>Mean impact factor</th>
          <th>Median impact factor</th>
          <th>Median JCI</th>
          <th>Q1 share</th>
          <th>Top publishers</th>
          <th>Missing count</th>
          <th>Missing share</th>
        </tr>
      </thead>
      <tbody>
        {% for row in jcr_summary %}
        <tr>
          <td>{{ row.platform }}</td>
          <td>{{ row.eligible_count if row.eligible_count is not none else "N/A" }}</td>
          <td>{{ "%.2f"|format(row.mean) if row.mean is not none else "N/A" }}</td>
          <td>{{ "%.2f"|format(row.median) if row.median is not none else "N/A" }}</td>
          <td>{{ "%.2f"|format(row.median_jci) if row.median_jci is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.q1_share * 100) if row.q1_share is not none else "N/A" }}</td>
          <td>{{ row.top_publishers if row.top_publishers is not none else "N/A" }}</td>
          <td>{{ row.missing_count if row.missing_count is not none else "N/A" }}</td>
          <td>{{ "%.1f%%"|format(row.missing_share * 100) if row.missing_share is not none else "N/A" }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </section>

  <section>
    <h2>Scopus enrichment</h2>
    {% if scopus_summary %}
    <table>
      <thead>
        <tr>
          <th>Total records</th>
          <th>Scopus enriched</th>
          <th>Scopus enriched %</th>
          <th>With cited-by count</th>
          <th>With serial metrics</th>
          <th>With citation overview</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{ scopus_summary.total }}</td>
          <td>{{ scopus_summary.enriched_count }}</td>
          <td>{{ "%.1f%%"|format(scopus_summary.enriched_pct) }}</td>
          <td>{{ scopus_summary.with_citedby_count }}</td>
          <td>{{ scopus_summary.with_serial_metrics }}</td>
          <td>{{ scopus_summary.with_citation_overview }}</td>
        </tr>
      </tbody>
    </table>
    {% else %}
    <p>No Scopus enrichment summary available.</p>
    {% endif %}
  </section>

  <section>
    <h2>Sample Records</h2>
    {% if table %}
    <table>
      <thead>
        <tr>
          {% for key in table[0].keys() %}
          <th>{{ key }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in table %}
        <tr>
          {% for value in row.values() %}
          <td>{{ value }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>No sample records available.</p>
    {% endif %}
  </section>
</body>
</html>
