      <section id="raw-json" class="card">
        <h2>Raw JSON</h2>
        <details>
          <summary>Metrics JSON</summary>
          <pre>{{ latest_metrics | tojson(indent=2) }}</pre>
        </details>
        <details>
          <summary>Diagnostics JSON</summary>
          <pre>{{ diagnostics | tojson(indent=2) }}</pre>
        </details>
      </section>
    </main>
  </div>

  {% if interactive.plotly_js %}
  <script>{{ interactive.plotly_js | safe }}</script>
  {% elif interactive.plotly_cdn_url %}
  <script src="{{ interactive.plotly_cdn_url }}"></script>
  {% endif %}
  <script id="interactive-report-data" type="application/json">{{ interactive.payload | tojson }}</script>
  <script>
    (function () {
      const payloadNode = document.getElementById("interactive-report-data");
      if (!payloadNode) return;
      const data = JSON.parse(payloadNode.textContent || "{}");
      const llmSpecific = {{ llm_specific | tojson }};
      window.__REPORT_DATA__ = data;
      const hasPlotly = typeof window.Plotly !== "undefined";

      const platformFilter = document.getElementById("platform-filter");
      const metricFilter = document.getElementById("metric-group-filter");
      const topKFilter = document.getElementById("top-k-filter");
      const compareMode = document.getElementById("compare-mode-filter");
      const hideLow = document.getElementById("hide-low-reliability");
      const showMissing = document.getElementById("show-missingness-overlay");
      const geoVariantFilter = document.getElementById("geo-variant-filter");
      const geoGranularityFilter = document.getElementById("geo-granularity-filter");

      function selectedPlatform() { return (platformFilter && platformFilter.value) || "all"; }
      function selectedK() { return String(parseInt((topKFilter && topKFilter.value) || "10", 10)); }
      function currentPlatformData() {
        const platform = selectedPlatform();
        return (data.platform_data && (data.platform_data[platform] || data.platform_data.all)) || {};
      }

      function setPlaceholder(id, message) {
        const node = document.getElementById(id);
        if (node) node.textContent = message || "";
      }

      function chartOrPlaceholder(target, placeholder, traces, layout, reason) {
        const node = document.getElementById(target);
        if (!node) return;
        if (!hasPlotly || reason) {
          node.innerHTML = "";
          setPlaceholder(placeholder, reason || "Plotly unavailable.");
          return;
        }
        setPlaceholder(placeholder, "");
        window.Plotly.newPlot(target, traces, layout, { responsive: true, displayModeBar: true });
      }

      function formatShare(value) {
        if (value == null || Number.isNaN(Number(value))) return "-";
        return `${(Number(value) * 100).toFixed(1)}%`;
      }

      function reliabilityHidden(value) {
        return hideLow && hideLow.checked && value === "low";
      }

      function renderRecency() {
        const mode = (compareMode && compareMode.value) || "overlay";
        const selected = selectedPlatform();
        const recency = data.recency_overlay || {};
        const platforms = selected === "all" ? (data.platforms || []).filter((p) => p !== "all") : [selected];
        const traces = [];
        platforms.forEach((platform) => {
          const points = recency[platform] || [];
          if (!points.length) return;
          traces.push({
            type: "scatter",
            mode: "lines+markers",
            name: platform,
            x: points.map((p) => p.year),
            y: points.map((p) => p.count),
            visible: true,
          });
        });
        if (!traces.length) {
          chartOrPlaceholder("chart-recency", "placeholder-recency", [], {}, "Recency distribution unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-recency",
          "placeholder-recency",
          traces,
          {
            title: mode === "small_multiples" ? "Recency (small multiples mode shown as overlays in legend)" : undefined,
            margin: { t: 20, r: 20, b: 55, l: 45 },
            xaxis: { title: "Year" },
            yaxis: { title: "Count" },
          },
          null
        );
      }

      function renderRankCitations() {
        const platformData = currentPlatformData();
        const block = platformData.rank_vs_citations || {};
        if (reliabilityHidden(block.reliability)) {
          chartOrPlaceholder("chart-rank-citations", "placeholder-rank-citations", [], {}, "Hidden due to low reliability.");
          return;
        }
        const points = Array.isArray(block.points) ? block.points : [];
        if (!points.length) {
          chartOrPlaceholder("chart-rank-citations", "placeholder-rank-citations", [], {}, block.note || block.reason || "No citation points.");
          return;
        }
        chartOrPlaceholder(
          "chart-rank-citations",
          "placeholder-rank-citations",
          [{
            type: "scatter",
            mode: "markers",
            x: points.map((p) => p.rank),
            y: points.map((p) => p.citations),
            text: points.map((p) => `${p.title || "untitled"}<br>${p.doi || "-"}<br>year=${p.year || "-"}`),
            hovertemplate: "%{text}<br>rank=%{x}<br>citations=%{y}<extra></extra>",
            marker: { size: 8, color: "#bf4f34", opacity: 0.75 },
          }],
          { margin: { t: 20, r: 20, b: 55, l: 50 }, xaxis: { title: "Rank", autorange: "reversed" }, yaxis: { title: "Citations" } },
          null
        );
      }

      function renderOATopK() {
        const k = selectedK();
        const block = ((currentPlatformData().oa_top_k || {})[k]) || {};
        if (reliabilityHidden(block.reliability)) {
          chartOrPlaceholder("chart-oa-topk", "placeholder-oa-topk", [], {}, "Hidden due to low reliability.");
          return;
        }
        if (block.top_k_share == null || block.overall_share == null) {
          chartOrPlaceholder("chart-oa-topk", "placeholder-oa-topk", [], {}, "OA Top-K not available.");
          return;
        }
        const annotation = showMissing && showMissing.checked && block.missing_pct != null
          ? [{ text: `missing=${(block.missing_pct * 100).toFixed(1)}%`, x: 0.5, y: 1.08, showarrow: false, xref: "paper", yref: "paper", font: { size: 11, color: "#666" } }]
          : [];
        chartOrPlaceholder(
          "chart-oa-topk",
          "placeholder-oa-topk",
          [{ type: "bar", x: ["overall", `top-${k}`], y: [block.overall_share, block.top_k_share], marker: { color: ["#1f7a8c", "#bf4f34"] } }],
          { margin: { t: 30, r: 20, b: 55, l: 45 }, yaxis: { title: "OA share", range: [0, 1] }, annotations: annotation },
          null
        );
      }

      function renderDocType() {
        const k = selectedK();
        const block = ((currentPlatformData().doc_type_top_k || {})[k]) || {};
        if (reliabilityHidden(block.reliability)) {
          chartOrPlaceholder("chart-doc-type", "placeholder-doc-type", [], {}, "Hidden due to low reliability.");
          return;
        }
        const top = block.top_distribution || {};
        const overall = block.overall_distribution || {};
        const labels = Array.from(new Set([].concat(Object.keys(top), Object.keys(overall)))).slice(0, 10);
        if (!labels.length) {
          chartOrPlaceholder("chart-doc-type", "placeholder-doc-type", [], {}, "Doc type distribution unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-doc-type",
          "placeholder-doc-type",
          [
            { type: "bar", name: "overall", x: labels, y: labels.map((l) => overall[l] || 0), marker: { color: "#3d5a80" } },
            { type: "bar", name: `top-${k}`, x: labels, y: labels.map((l) => top[l] || 0), marker: { color: "#ee6c4d" } },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 85, l: 45 }, yaxis: { title: "Share", range: [0, 1] } },
          null
        );
      }

      function renderHHI() {
        const selected = selectedPlatform();
        const rows = Array.isArray(data.publisher_hhi) ? data.publisher_hhi : [];
        const visible = selected === "all" ? rows : rows.filter((r) => r.platform === selected);
        const available = visible.filter((r) => r.hhi != null);
        if (!available.length) {
          chartOrPlaceholder("chart-hhi", "placeholder-hhi", [], {}, (visible.find((r) => r.reason) || {}).reason || "HHI unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-hhi",
          "placeholder-hhi",
          [{ type: "bar", x: available.map((r) => r.platform), y: available.map((r) => r.hhi), marker: { color: "#6c757d" } }],
          { margin: { t: 20, r: 20, b: 55, l: 45 }, yaxis: { title: "HHI", range: [0, 1] } },
          null
        );
      }

      function renderOARecency() {
        const selected = selectedPlatform();
        const payload = data.oa_vs_recency || {};
        const platforms = selected === "all" ? (data.platforms || []).filter((p) => p !== "all") : [selected];
        const traces = [];
        platforms.forEach((platform) => {
          const points = payload[platform] || [];
          if (!points.length) return;
          traces.push({
            type: "scatter",
            mode: "markers+lines",
            name: platform,
            x: points.map((p) => p.year),
            y: points.map((p) => p.oa_share),
            marker: { size: points.map((p) => Math.max(7, Math.min(24, p.count + 4))), opacity: 0.7 },
          });
        });
        if (!traces.length) {
          chartOrPlaceholder("chart-oa-recency", "placeholder-oa-recency", [], {}, "OA vs recency unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-oa-recency",
          "placeholder-oa-recency",
          traces,
          { margin: { t: 20, r: 20, b: 55, l: 45 }, xaxis: { title: "Year" }, yaxis: { title: "OA share", range: [0, 1] } },
          null
        );
      }

      function renderPlatformCompare() {
        const rows = Array.isArray(data.platform_compare) ? data.platform_compare : [];
        if (!rows.length) {
          chartOrPlaceholder("chart-platform-compare", "placeholder-platform-compare", [], {}, "Platform compare unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-platform-compare",
          "placeholder-platform-compare",
          [
            { type: "bar", name: "Median year", x: rows.map((r) => r.platform), y: rows.map((r) => r.median_year) },
            { type: "bar", name: "OA share", x: rows.map((r) => r.platform), y: rows.map((r) => r.oa_share), yaxis: "y2" },
            { type: "bar", name: "Publisher HHI", x: rows.map((r) => r.platform), y: rows.map((r) => r.publisher_hhi), yaxis: "y2" },
          ],
          {
            barmode: "group",
            margin: { t: 20, r: 40, b: 55, l: 45 },
            yaxis: { title: "Median year" },
            yaxis2: { title: "Share / HHI", overlaying: "y", side: "right", range: [0, 1] },
          },
          null
        );
      }

      function renderMissingness() {
        const missing = data.missingness || {};
        const z = Array.isArray(missing.z) ? missing.z : [];
        if (!z.length) {
          chartOrPlaceholder("chart-missingness", "placeholder-missingness", [], {}, "Missingness heatmap unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-missingness",
          "placeholder-missingness",
          [{ type: "heatmap", x: missing.fields || [], y: missing.platforms || [], z, colorscale: "Reds", zmin: 0, zmax: 1, hovertemplate: "platform=%{y}<br>field=%{x}<br>missing=%{z:.2f}<extra></extra>" }],
          { margin: { t: 20, r: 20, b: 60, l: 110 } },
          null
        );
      }

      function renderEnrichmentGain() {
        const selected = selectedPlatform();
        const block = data.enrichment_gain || {};
        const fields = block.fields || [];
        if (!fields.length) {
          chartOrPlaceholder("chart-enrichment-gain", "placeholder-enrichment-gain", [], {}, "Enrichment gain unavailable.");
          return;
        }
        const source = selected === "all"
          ? block.overall || {}
          : ((block.per_platform || {})[selected] || {});
        const before = source.before || {};
        const after = source.after || {};
        chartOrPlaceholder(
          "chart-enrichment-gain",
          "placeholder-enrichment-gain",
          [
            { type: "bar", name: "before", x: fields, y: fields.map((f) => before[f]), marker: { color: "#9aa5b1" } },
            { type: "bar", name: "after", x: fields, y: fields.map((f) => after[f]), marker: { color: "#1f7a8c" } },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 90, l: 45 }, yaxis: { title: "Coverage", range: [0, 1] } },
          null
        );
      }

      function renderOverlap() {
        const overlap = data.overlap || {};
        const z = overlap.z || [];
        if (!Array.isArray(z) || !z.length) {
          chartOrPlaceholder("chart-overlap", "placeholder-overlap", [], {}, "Overlap matrix unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-overlap",
          "placeholder-overlap",
          [{ type: "heatmap", x: overlap.platforms || [], y: overlap.platforms || [], z, colorscale: "Blues", zmin: 0, zmax: 1, hovertemplate: "%{y} vs %{x}<br>Jaccard=%{z:.3f}<extra></extra>" }],
          { margin: { t: 20, r: 20, b: 55, l: 110 } },
          null
        );
      }

      function renderCoreRankBias() {
        const selected = selectedPlatform();
        const k = selectedK();
        const payload = data.core_rank_topk_vs_rest || {};
        const rows = selected === "all" ? (data.platforms || []).filter((p) => p !== "all") : [selected];
        const points = rows.map((platform) => ({ platform, item: (payload[platform] || {})[k] || {} }));
        if (!points.some((p) => p.item.top_k_share != null || p.item.rest_share != null)) {
          chartOrPlaceholder("chart-core-rank-bias", "placeholder-core-rank-bias", [], {}, "CORE rank bias unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-core-rank-bias",
          "placeholder-core-rank-bias",
          [
            { type: "bar", name: `top-${k}`, x: points.map((p) => p.platform), y: points.map((p) => p.item.top_k_share) },
            { type: "bar", name: "rest", x: points.map((p) => p.platform), y: points.map((p) => p.item.rest_share) },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 55, l: 45 }, yaxis: { title: "Share", range: [0, 1] } },
          null
        );
      }

      function renderJIFQuartileBias() {
        const selected = selectedPlatform();
        const k = selectedK();
        const payload = data.jif_quartile_topk_vs_rest || {};
        const rows = selected === "all" ? (data.platforms || []).filter((p) => p !== "all") : [selected];
        const topShares = [];
        const restShares = [];
        rows.forEach((platform) => {
          const item = (((payload[platform] || {})[k]) || {});
          const top = (item.top || {});
          const rest = (item.rest || {});
          topShares.push(top.Q1 || 0);
          restShares.push(rest.Q1 || 0);
        });
        if (!topShares.some((v) => v > 0) && !restShares.some((v) => v > 0)) {
          chartOrPlaceholder("chart-jif-quartile-bias", "placeholder-jif-quartile-bias", [], {}, "JIF quartile bias unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-jif-quartile-bias",
          "placeholder-jif-quartile-bias",
          [
            { type: "bar", name: `top-${k} Q1`, x: rows, y: topShares },
            { type: "bar", name: "rest Q1", x: rows, y: restShares },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 55, l: 45 }, yaxis: { title: "Q1 share", range: [0, 1] } },
          null
        );
      }

      function renderGeoBias() {
        const block = currentPlatformData().geo_bias || {};
        const enabled = !!block.enabled_for_bias_metrics;
        const reason = block.reason || "";
        const availableShare = document.getElementById("geo-available-share");
        const multiShare = document.getElementById("geo-multi-share");
        const enabledNode = document.getElementById("geo-enabled");
        const reasonNode = document.getElementById("geo-reason");
        if (availableShare) availableShare.textContent = formatShare(block.available_share);
        if (multiShare) multiShare.textContent = formatShare(block.multi_country_share ?? block.multi_share);
        if (enabledNode) enabledNode.textContent = enabled ? "enabled" : "disabled";
        if (reasonNode) reasonNode.textContent = reason || "-";

        const k = selectedK();
        const variant = (geoVariantFilter && geoVariantFilter.value) || "fractional";
        const granularity = (geoGranularityFilter && geoGranularityFilter.value) || "countries";
        const overallVariants = block.overall_distribution_variants || {};
        const overallDistribution = (((overallVariants[granularity] || {})[variant]) || {});
        const perK = ((block.per_k || {})[k]) || {};
        const variantPayload = ((((perK.variants || {})[granularity] || {})[variant]) || {});
        const topDistribution = variantPayload.top_distribution || {};
        const overRatio = variantPayload.overrepresentation_ratio || {};

        if (!enabled) {
          chartOrPlaceholder("chart-geo-top", "placeholder-geo-top", [], {}, reason || "Geo bias disabled by gating.");
          chartOrPlaceholder("chart-geo-overunder", "placeholder-geo-overunder", [], {}, reason || "Geo bias disabled by gating.");
          return;
        }

        const labels = Array.from(
          new Set(
            Object.keys(overallDistribution || {})
              .concat(Object.keys(topDistribution || {}))
          )
        )
          .map((label) => ({
            label,
            score: Math.max(Number(overallDistribution[label] || 0), Number(topDistribution[label] || 0)),
          }))
          .sort((a, b) => b.score - a.score)
          .slice(0, 10)
          .map((item) => item.label);
        if (!labels.length) {
          chartOrPlaceholder("chart-geo-top", "placeholder-geo-top", [], {}, "Geo distribution unavailable.");
          chartOrPlaceholder("chart-geo-overunder", "placeholder-geo-overunder", [], {}, "Geo over/under unavailable.");
          return;
        }

        chartOrPlaceholder(
          "chart-geo-top",
          "placeholder-geo-top",
          [
            { type: "bar", name: "overall", x: labels, y: labels.map((l) => overallDistribution[l] || 0), marker: { color: "#3d5a80" } },
            { type: "bar", name: `top-${k}`, x: labels, y: labels.map((l) => topDistribution[l] || 0), marker: { color: "#ee6c4d" } },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 85, l: 45 }, yaxis: { title: "Share", range: [0, 1] } },
          null
        );

        const ratioEntries = Object.entries(overRatio || {})
          .filter(([, value]) => Number.isFinite(Number(value)));
        const overEntries = ratioEntries
          .filter(([, value]) => Number(value) >= 1)
          .sort((a, b) => Number(b[1]) - Number(a[1]))
          .slice(0, 10);
        const underEntries = ratioEntries
          .filter(([, value]) => Number(value) < 1)
          .sort((a, b) => Number(a[1]) - Number(b[1]))
          .slice(0, 10);
        const ratioLabels = overEntries.concat(underEntries).map(([label]) => label);
        if (!ratioLabels.length) {
          chartOrPlaceholder("chart-geo-overunder", "placeholder-geo-overunder", [], {}, "Over/under ratio unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-geo-overunder",
          "placeholder-geo-overunder",
          [
            {
              type: "bar",
              x: ratioLabels,
              y: ratioLabels.map((l) => overRatio[l]),
              marker: {
                color: ratioLabels.map((l) => (Number(overRatio[l]) >= 1 ? "#1f7a8c" : "#bf4f34")),
              },
            },
          ],
          { margin: { t: 20, r: 20, b: 85, l: 45 }, yaxis: { title: "Overrepresentation ratio" } },
          null
        );
      }

      function renderVenueDiversity() {
        const selected = selectedPlatform();
        const k = selectedK();
        const payload = data.venue_diversity || {};
        const rows = selected === "all" ? (data.platforms || []).filter((p) => p !== "all") : [selected];
        const values = rows.map((platform) => {
          const perK = (((payload[platform] || {}).per_k || {})[k]) || {};
          return perK.top_k_diversity || 0;
        });
        if (!values.length) {
          chartOrPlaceholder("chart-venue-diversity", "placeholder-venue-diversity", [], {}, "Venue diversity unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-venue-diversity",
          "placeholder-venue-diversity",
          [{ type: "bar", x: rows, y: values, marker: { color: "#1f7a8c" } }],
          { margin: { t: 20, r: 20, b: 55, l: 45 }, yaxis: { title: "Unique journals / top-k", range: [0, 1] } },
          null
        );
      }

      function renderLLMHallucination() {
        if (!llmSpecific || !llmSpecific.present) return;
        const rows = (llmSpecific.hallucination_rows || []).filter((row) => row.model !== "overall");
        if (!rows.length) {
          chartOrPlaceholder("chart-llm-hallucination", "placeholder-llm-hallucination", [], {}, "LLM verification data unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-llm-hallucination",
          "placeholder-llm-hallucination",
          [
            { type: "bar", name: "Verified", x: rows.map((row) => row.model), y: rows.map((row) => row.matched_proportion || 0) },
            { type: "bar", name: "Unmatched", x: rows.map((row) => row.model), y: rows.map((row) => row.unmatched_proportion || 0) },
            { type: "bar", name: "Conflict", x: rows.map((row) => row.model), y: rows.map((row) => row.any_conflict_rate || 0) },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 75, l: 45 }, yaxis: { title: "Rate", range: [0, 1] } },
          null
        );
      }

      function renderLLMParse() {
        if (!llmSpecific || !llmSpecific.present) return;
        const rows = (llmSpecific.parse_rows || []).filter((row) => row.model !== "overall");
        if (!rows.length) {
          chartOrPlaceholder("chart-llm-parse", "placeholder-llm-parse", [], {}, "LLM parse metrics unavailable.");
          return;
        }
        chartOrPlaceholder(
          "chart-llm-parse",
          "placeholder-llm-parse",
          [
            { type: "bar", name: "Strict JSON", x: rows.map((row) => row.model), y: rows.map((row) => row.strict_json_rate || 0) },
            { type: "bar", name: "Fallback", x: rows.map((row) => row.model), y: rows.map((row) => row.repaired_parse_rate || 0) },
            { type: "bar", name: "Failures", x: rows.map((row) => row.model), y: rows.map((row) => row.parse_failure_rate || 0) },
          ],
          { barmode: "group", margin: { t: 20, r: 20, b: 75, l: 45 }, yaxis: { title: "Rate", range: [0, 1] } },
          null
        );
      }

      function applyMetricGroupVisibility() {
        const selected = (metricFilter && metricFilter.value) || "all";
        document.querySelectorAll(".chart-card[data-group]").forEach((node) => {
          const group = node.getAttribute("data-group");
          node.style.display = selected === "all" || selected === group ? "block" : "none";
        });
      }

      function renderAll() {
        applyMetricGroupVisibility();
        renderRecency();
        renderRankCitations();
        renderOATopK();
        renderDocType();
        renderHHI();
        renderOARecency();
        renderPlatformCompare();
        renderMissingness();
        renderEnrichmentGain();
        renderOverlap();
        renderCoreRankBias();
        renderJIFQuartileBias();
        renderGeoBias();
        renderVenueDiversity();
        renderLLMHallucination();
        renderLLMParse();
      }

      [platformFilter, metricFilter, topKFilter, compareMode, hideLow, showMissing, geoVariantFilter, geoGranularityFilter].forEach((node) => {
        if (node) node.addEventListener("change", renderAll);
      });
      renderAll();

      function filterTable(tableId, query) {
        const table = document.getElementById(tableId);
        if (!table) return;
        const q = (query || "").trim().toLowerCase();
        const rows = table.querySelectorAll("tbody tr");
        rows.forEach((row) => {
          const text = row.textContent.toLowerCase();
          row.style.display = !q || text.includes(q) ? "" : "none";
        });
      }

      document.querySelectorAll(".table-filter").forEach((input) => {
        const target = input.getAttribute("data-target");
        input.addEventListener("input", () => filterTable(target, input.value));
      });

      function sortTableByColumn(table, columnIndex, asc) {
        const dir = asc ? 1 : -1;
        const tbody = table.tBodies[0];
        const rows = Array.from(tbody.querySelectorAll("tr"));
        rows.sort((a, b) => {
          const aText = (a.children[columnIndex] || {}).textContent || "";
          const bText = (b.children[columnIndex] || {}).textContent || "";
          const aNum = Number(aText.replace(/[^0-9.+-]/g, ""));
          const bNum = Number(bText.replace(/[^0-9.+-]/g, ""));
          if (!Number.isNaN(aNum) && !Number.isNaN(bNum) && aText.trim() && bText.trim()) {
            return (aNum - bNum) * dir;
          }
          return aText.localeCompare(bText) * dir;
        });
        rows.forEach((row) => tbody.appendChild(row));
      }

      document.querySelectorAll("table.js-table th").forEach((th) => {
        th.addEventListener("click", () => {
          const table = th.closest("table");
          if (!table) return;
          const index = Array.from(th.parentElement.children).indexOf(th);
          const asc = !th.classList.contains("sort-asc");
          table.querySelectorAll("th").forEach((node) => node.classList.remove("sort-asc", "sort-desc"));
          th.classList.add(asc ? "sort-asc" : "sort-desc");
          sortTableByColumn(table, index, asc);
        });
      });

      const llmQueryFilter = document.getElementById("llm-query-filter");
      if (llmQueryFilter) {
        llmQueryFilter.addEventListener("input", () => {
          const query = llmQueryFilter.value.trim().toLowerCase();
          document.querySelectorAll(".llm-query-card").forEach((card) => {
            const text = (card.getAttribute("data-search") || "").toLowerCase();
            card.style.display = !query || text.includes(query) ? "" : "none";
          });
        });
      }
    })();
  </script>
</body>
</html>
